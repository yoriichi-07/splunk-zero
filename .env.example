# Splunk MCP
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_TOKEN=your_mcp_encrypted_token_here
SPLUNK_MCP_URL=https://localhost:8089/services/mcp

# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=your-username/splunk-zero-demo-app
GITHUB_BRANCH_PREFIX=splunk-zero

# LLM
GOOGLE_API_KEY=your_gemini_api_key
LLM_MODEL=gemini-3.1-flash-lite

# App
APP_PORT=8000
COST_PER_GB_PER_DAY=15
WASTE_THRESHOLD_PCT=5
MIN_SEARCH_COUNT=2
ANALYSIS_PERIOD_DAYS=30
